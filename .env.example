# Zyden Edu E2E Playwright — environment variables
# Copy this to .env.local and fill in values. Never commit .env.local.

# Frontend web app URL
FRONTEND_URL=https://school-dev.zydenlabs.com

# Backend API URL
BACKEND_URL=https://school-api-dev.zydenlabs.com

# Auth service URL
AUTH_URL=https://auth-dev.zydenlabs.com

# Postgres QA writer connection string (restricted role — school-test-qa tenant only)
# Format: postgresql://qa_test_writer:<password>@<host>:5432/school_dev
# Obtained from Zaid / .env.local on the dev machine
POSTGRES_QA_WRITER_URL=postgresql://qa_test_writer:CHANGEME@HOSTNAME:5432/school_dev
